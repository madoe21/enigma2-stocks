# Copy this file to .env and fill in your box credentials
BOX_HOST=192.168.1.xxx
BOX_PORT=22
BOX_USER=root

# Pre-deploy stocks to watchlist by Yahoo symbol, ISIN, or WKN.
# Comma-separated list. ISINs and WKNs are resolved to Yahoo symbols
# at deploy time via the Yahoo Finance search API.
# Examples:
#   STOCKS_WATCHLIST=SAP.DE,ADS.DE,SIE.DE
#   STOCKS_WATCHLIST=DE0007164600,DE000A1EWWW0
#   STOCKS_WATCHLIST=716460,A1EWWW
STOCKS_WATCHLIST=
