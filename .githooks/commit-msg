#!/usr/bin/env bash
# Enforce Conventional Commits. Bypass (discouraged): AIFLOW_SKIP_COMMIT_LINT=1
[ "${AIFLOW_SKIP_COMMIT_LINT:-}" = "1" ] && exit 0
msg="$(head -n1 "$1")"
pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9_-]+\))?!?: .{1,}'
if ! printf '%s' "$msg" | grep -Eq "$pattern"; then
  cat >&2 <<EOF
✗ Commit message is not a Conventional Commit.
  Got:      $msg
  Expected: <type>(<scope>): <subject>     e.g. feat(auth): add token refresh (bd-12)
  Types: feat fix docs style refactor perf test build ci chore revert
EOF
  exit 1
fi
exit 0
